---
import Header from "@/components/Header.astro";
import FanSection from "@/components/FanSection.astro";
import Footer from "@/components/Footer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { getFanInfo } from "@/lib/content";
import { isLocale, locales } from "@/lib/i18n";
import { getMessages } from "@/i18n/messages";
import type { Locale } from "@/types/content";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  throw new Error(`Invalid locale: ${localeParam}`);
}

const locale: Locale = localeParam;
const messages = getMessages(locale);
const fanInfo = await getFanInfo();
---

<BaseLayout title={`${messages.nav.fan} | ${messages.siteTitle}`} description={messages.siteSubtitle} locale={locale}>
  <Header locale={locale} pathSuffix="/fan" messages={messages} />
  <main class="page-main">
    <PageHero title={messages.sections.fan} subtitle={messages.siteSubtitle} />
    <FanSection locale={locale} fanInfo={fanInfo} messages={messages} />
  </main>
  <Footer />
</BaseLayout>
