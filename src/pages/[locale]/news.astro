---
import Header from "@/components/Header.astro";
import NewsSection from "@/components/NewsSection.astro";
import Footer from "@/components/Footer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { getNews } from "@/lib/content";
import { isLocale, locales } from "@/lib/i18n";
import { getMessages } from "@/i18n/messages";
import type { Locale } from "@/types/content";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  throw new Error(`Invalid locale: ${localeParam}`);
}

const locale: Locale = localeParam;
const messages = getMessages(locale);
const news = await getNews();
const sortedNews = [...news].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title={`${messages.nav.news} | ${messages.siteTitle}`} description={messages.siteSubtitle} locale={locale}>
  <Header locale={locale} pathSuffix="/news" messages={messages} />
  <main class="page-main">
    <PageHero title={messages.sections.news} subtitle={messages.siteSubtitle} />
    <NewsSection locale={locale} news={sortedNews} messages={messages} />
  </main>
  <Footer />
</BaseLayout>
