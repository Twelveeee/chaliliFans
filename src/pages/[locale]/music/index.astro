---
import Header from "@/components/Header.astro";
import MusicSection from "@/components/MusicSection.astro";
import Footer from "@/components/Footer.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import FloatingPlaylistPlayer from "@/components/FloatingPlaylistPlayer.astro";
import { getSongs } from "@/lib/content";
import { isLocale, locales } from "@/lib/i18n";
import { getMessages } from "@/i18n/messages";
import type { Locale } from "@/types/content";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  throw new Error(`Invalid locale: ${localeParam}`);
}

const locale: Locale = localeParam;
const messages = getMessages(locale);
const songs = await getSongs();
---

<BaseLayout title={`${messages.nav.music} | ${messages.siteTitle}`} description={messages.siteSubtitle} locale={locale}>
  <Header locale={locale} pathSuffix="/music" messages={messages} />
  <main class="page-main">
    <PageHero title={messages.sections.music} subtitle={messages.siteSubtitle} />
    <MusicSection locale={locale} songs={songs} messages={messages} />
  </main>
  <FloatingPlaylistPlayer />
  <Footer />
</BaseLayout>
